{
  "title": "listing-service",
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "Connections vs Max",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "svc_active_connections{service=\"listing-service\"}",
          "legendFormat": "active connections",
          "refId": "A"
        },
        {
          "expr": "svc_max_connections{service=\"listing-service\"}",
          "legendFormat": "max connections",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "svc_cache_hit_ratio{service=\"listing-service\"}",
          "legendFormat": "cache hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.85},
              {"color": "red", "value": 0.70}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"}
      }
    },
    {
      "title": "p99 Latency & Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "svc_p99_latency_ms{service=\"listing-service\"}",
          "legendFormat": "p99 (ms)",
          "refId": "A"
        },
        {
          "expr": "svc_error_rate_pct{service=\"listing-service\"}",
          "legendFormat": "error rate (%)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "listing-service Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "{service=\"listing-service\"}",
          "refId": "A"
        }
      ],
      "datasource": "Loki",
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogs": true
      }
    }
  ],
  "schemaVersion": 39,
  "refresh": "15s"
}
