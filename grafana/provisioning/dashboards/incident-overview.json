{
  "title": "Incident Overview",
  "version": 2,
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "p99 Latency — all services",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "svc_p99_latency_ms",
          "legendFormat": "{{service}}{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1000},
              {"color": "red", "value": 1500}
            ]
          },
          "min": 0
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "Error Rate — all services",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "svc_error_rate_pct",
          "legendFormat": "{{service}}{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 2},
              {"color": "red", "value": 5}
            ]
          },
          "min": 0
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "Active Connections vs Max — pool-backed services",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "svc_active_connections",
          "legendFormat": "{{service}} active",
          "refId": "A"
        },
        {
          "expr": "svc_max_connections",
          "legendFormat": "{{service}} max",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 150},
              {"color": "red", "value": 190}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "Cache Hit Ratio — cache-backed services",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "svc_cache_hit_ratio",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.85},
              {"color": "red", "value": 0.70}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "Errors by Type — all services",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (service, error_type) (rate(svc_errors_total[1m]))",
          "legendFormat": "{{service}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Recent Error Logs — all services",
      "type": "logs",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "{source=\"incident-generator\"} |= \"ERROR\"",
          "refId": "A"
        }
      ],
      "datasource": "Loki",
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogs": true
      }
    }
  ],
  "schemaVersion": 39,
  "refresh": "15s"
}
