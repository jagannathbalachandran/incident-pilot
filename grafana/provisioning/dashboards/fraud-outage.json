{
  "title": "Fraud Outage",
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "Error Rate (Fraud Spike) — fraud-scoring-svc vs checkout-api",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "svc_error_rate_pct{service=\"fraud-scoring-svc\"}",
          "legendFormat": "fraud-scoring-svc error rate (%)",
          "refId": "A"
        },
        {
          "expr": "svc_error_rate_pct{service=\"checkout-api\", endpoint=\"/checkout\"}",
          "legendFormat": "checkout-api /checkout error rate (%) (cascade)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 2},
              {"color": "red", "value": 8}
            ]
          }
        }
      }
    },
    {
      "title": "p99 Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "svc_p99_latency_ms{service=\"fraud-scoring-svc\"}",
          "legendFormat": "fraud-scoring-svc p99 (ms)",
          "refId": "A"
        },
        {
          "expr": "svc_upstream_duration_ms_sum{service=\"checkout-api\", upstream=\"fraud-scoring-svc\"} / svc_upstream_duration_ms_count{service=\"checkout-api\", upstream=\"fraud-scoring-svc\"}",
          "legendFormat": "checkout-api -> fraud-scoring-svc avg call latency (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      }
    },
    {
      "title": "Fraud Error Count",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(svc_errors_total{service=\"fraud-scoring-svc\", error_type=\"fraud_svc_unavailable\"}[1m]))",
          "legendFormat": "fraud-scoring-svc errors / sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(svc_errors_total{service=\"checkout-api\", error_type=\"upstream_error\"}[1m]))",
          "legendFormat": "checkout-api upstream errors / sec (cascade)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "title": "Fraud Error Logs",
      "type": "logs",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "{service=\"fraud-scoring-svc\"} |= \"fraud-scoring-svc\"",
          "refId": "A"
        }
      ],
      "datasource": "Loki"
    }
  ],
  "schemaVersion": 39,
  "refresh": "15s"
}
