{
  "title": "Cache Failover",
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "checkout_cache_hit_ratio{service=\"checkout-api\"}",
          "legendFormat": "cache hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.85},
              {"color": "red", "value": 0.70}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"}
      }
    },
    {
      "title": "p99 Latency (Cache Impact)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "checkout_p99_latency_ms{service=\"checkout-api\"}",
          "legendFormat": "p99 latency (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 600},
              {"color": "red", "value": 1000}
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (Should Stay Low)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "checkout_error_rate_pct{service=\"checkout-api\"}",
          "legendFormat": "error rate (%)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 5
        }
      }
    },
    {
      "title": "Cache Warning Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "{service=\"checkout-api\"} |= \"cache\"",
          "refId": "A"
        }
      ],
      "datasource": "Loki"
    }
  ],
  "schemaVersion": 39,
  "refresh": "15s"
}
