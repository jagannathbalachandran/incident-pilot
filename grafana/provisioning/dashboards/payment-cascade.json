{
  "title": "Payment Cascade (checkout-api -> payment-service)",
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "p99 Latency — payment-service (own) vs checkout-api /payment (caller)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "svc_p99_latency_ms{service=\"payment-service\"}",
          "legendFormat": "payment-service /charge p99 (ms)",
          "refId": "A"
        },
        {
          "expr": "svc_p99_latency_ms{service=\"checkout-api\", endpoint=\"/payment\"}",
          "legendFormat": "checkout-api /payment p99 (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 400},
              {"color": "red", "value": 700}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "checkout-api's call latency into payment-service",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "svc_upstream_duration_ms_sum{service=\"checkout-api\", upstream=\"payment-service\"} / svc_upstream_duration_ms_count{service=\"checkout-api\", upstream=\"payment-service\"}",
          "legendFormat": "avg call latency into payment-service (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"}
      }
    },
    {
      "title": "Error Rate — payment-service (own) vs checkout-api /payment (cascade)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "svc_error_rate_pct{service=\"payment-service\"}",
          "legendFormat": "payment-service /charge error rate (%)",
          "refId": "A"
        },
        {
          "expr": "svc_error_rate_pct{service=\"checkout-api\", endpoint=\"/payment\"}",
          "legendFormat": "checkout-api /payment error rate (%)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 2},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {
        "legend": {"show": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "title": "checkout-api upstream_error logs (attributed to payment-service)",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "{service=\"checkout-api\"} |= \"upstream dependency failed: payment-service\"",
          "refId": "A"
        }
      ],
      "datasource": "Loki",
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogs": true
      }
    }
  ],
  "schemaVersion": 39,
  "refresh": "15s"
}
