              "body": "{\n  \"status\": \"started\",\n  \"kind\": \"cache\",\n  \"phase\": \"climbing\",\n  \"tick_count\": 0,\n  \"request_id\": \"a1b2c3d4e5f6\"\n}"
            }
          ]
        },
