              "raw": "{\n  \"auto_resolve\": true\n}"
            },
            "description": "Start a Redis cache node failover scenario.\n\nLifecycle: climbing → failover (6s) → warming (12s) → auto-resolve\n\nKey difference from pool: NO error spike during cache incidents."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Scenario started\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status', 'started');",
                  "    pm.expect(json).to.have.property('kind', 'cache');",
                  "    pm.expect(json).to.have.property('request_id');",
                  "    pm.expect(json.request_id).to.match(/^[a-f0-9]{12}$/);",
                  "});",
                  "pm.test(\"Response has X-Request-ID header\", () => {",
                  "    pm.expect(pm.response.headers.get('X-Request-ID')).to.match(/^[a-f0-9]{12}$/);",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "Cache started",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "X-Request-ID",
                  "value": "a1b2c3d4e5f6"
                }
